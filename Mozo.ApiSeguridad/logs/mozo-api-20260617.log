    InternalPosition: 36
    InternalQuery: WITH hijos AS (
    SELECT
        coempresa,
        cotipopadre,
        cogrupopadre,
        COUNT(*) AS qthijo
    FROM maestro.trftipoparticular
    WHERE fldelete = false
    GROUP BY coempresa, cotipopadre, cogrupopadre
),
grupos AS (
    SELECT
        cotipo,
        cogrupopadre
    FROM maestro.trftipoparticular
    WHERE fldelete = false
      AND cogrupo = 0
)
SELECT
    COUNT(*) OVER() AS rowscount,
    tipo.coempresa,
    tipo.comodulo,
    tipo.cotipo,
    tipo.cogrupo,
    tipo.notipo,
    tipo.nosigla,
    tipo.fldefault::int,
    tipo.flestreg::int,
    tipo.nuorden,
    tipo.cotipopadre,
    g.cogrupopadre AS cogrupohijo,
    COALESCE(h.qthijo,0) AS qthijo
FROM maestro.trftipoparticular tipo
LEFT JOIN grupos g
       ON g.cotipo = tipo.cogrupo
LEFT JOIN hijos h
       ON h.coempresa = tipo.coempresa
      AND h.cotipopadre = tipo.cotipo
      AND h.cogrupopadre = tipo.cogrupo
WHERE tipo.coempresa = p_coempresa
  AND tipo.cogrupo = p_cogrupo
  AND tipo.fldelete = false
  AND (
        p_noinputsearch IS NULL
        OR tipo.notipo LIKE '%' || p_noinputsearch || '%'
        OR tipo.nosigla LIKE '%' || p_noinputsearch || '%'
        OR tipo.txdescripcion LIKE '%' || p_noinputsearch || '%'
        OR tipo.novalor LIKE '%' || p_noinputsearch || '%'
      )
  AND (p_flestreg IS NULL OR tipo.flestreg = p_flestreg::boolean)
  AND (p_cotipo IS NULL OR tipo.cotipo = p_cotipo)
ORDER BY tipo.nuorden
OFFSET COALESCE(p_pageindex,0) * COALESCE(p_pagesize,10)
LIMIT COALESCE(p_pagesize,10)
